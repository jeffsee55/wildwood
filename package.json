{
  "name": "wildwood-mono",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "start": "turbo start",
    "dev": "turbo dev",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "typecheck": "turbo typecheck",
    "dev:web": "turbo run watch:deps next:dev studio:play --filter=wildwood --filter=wildwood-kit --filter=wildwood-vscode --filter=play",
    "dev:web-play": "pnpm run dev:web",
    "dev:docs": "turbo run watch:deps next:dev studio:play --filter=wildwood --filter=wildwood-kit --filter=wildwood-vscode --filter=docs",
    "playground": "pnpm run dev:web",
    "dev:vscode-playground": "turbo run playground studio --filter=wildwood",
    "studio:wildwood": "turbo run studio --filter=wildwood",
    "studio:web-db": "turbo run studio:play --filter=wildwood",
    "test:wildwood": "turbo run test --filter=wildwood",
    "test:wildwood:watch": "turbo run test:watch --filter=wildwood"
  },
  "devDependencies": {
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "syncpack": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@clerk/shared",
      "@parcel/watcher",
      "@swc/core",
      "better-sqlite3",
      "core-js-pure",
      "esbuild",
      "lmdb",
      "msgpackr-extract",
      "sharp"
    ]
  }
}
