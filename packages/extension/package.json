{
  "name": "wildwood-vscode",
  "version": "0.1.0",
  "description": "Wildwood for VS Code — Git CMS editing",
  "categories": [
    "Other"
  ],
  "author": "Jeff See <jeff@wildwood.dev>",
  "license": "MIT",
  "publisher": "jsee",
  "type": "commonjs",
  "main": "./dist/extension.js",
  "browser": "./dist/extension.js",
  "types": "./dist/extension.d.ts",
  "files": [
    "dist",
    "package.json",
    "package.nls.json",
    "themes"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lib:dev": "tsdown --watch",
    "watch:deps": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "format": "oxfmt ."
  },
  "contributes": {
    "configuration": {
      "type": "object",
      "title": "Wildwood",
      "properties": {
        "wildwood.repo": {
          "type": "string",
          "description": "GitHub owner/repo (e.g. \"acme/website\")."
        },
        "wildwood.ref": {
          "type": "string",
          "default": "main",
          "description": "Default git ref when no headRef is configured."
        },
        "wildwood.headRef": {
          "type": "string",
          "description": "Active git ref for the editor (set via configurationDefaults)."
        },
        "wildwood.baseRef": {
          "type": "string",
          "description": "Comparison base ref (e.g. \"main\")."
        },
        "tr33.repo": {
          "type": "string",
          "description": "[Deprecated] Use wildwood.repo"
        },
        "tr33.ref": {
          "type": "string",
          "description": "[Deprecated] Use wildwood.ref"
        },
        "tr33.headRef": {
          "type": "string",
          "description": "[Deprecated] Use wildwood.headRef"
        },
        "tr33.baseRef": {
          "type": "string",
          "description": "[Deprecated] Use wildwood.baseRef"
        }
      }
    },
    "themes": [
      {
        "label": "Wildwood Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/wildwood-dark.json"
      }
    ],
    "viewsWelcome": [
      {
        "view": "debug",
        "contents": "In order to run and debug you'll need to create a local workspace."
      },
      {
        "view": "terminal",
        "contents": "In order to run and debug you'll need to create a local workspace."
      }
    ],
    "commands": [
      {
        "command": "wildwood.switchBranch",
        "title": "Switch branch",
        "category": "Wildwood"
      },
      {
        "command": "wildwood.source-control.commit",
        "title": "Commit",
        "category": "Wildwood",
        "icon": "$(check)"
      },
      {
        "command": "wildwood.source-control.commitAndPush",
        "title": "Commit & Push",
        "category": "Wildwood",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "wildwood.source-control.commitAndSyncWithPull",
        "title": "Commit & Sync (pull first)",
        "category": "Wildwood",
        "icon": "$(sync)"
      },
      {
        "command": "wildwood.source-control.commitAndMerge",
        "title": "Commit & Merge",
        "category": "Wildwood",
        "icon": "$(git-merge)"
      },
      {
        "command": "wildwood.source-control.main.commitAndMerge",
        "title": "Create PR & Merge (Main Compare)",
        "category": "Wildwood",
        "icon": "$(git-pull-request-create)"
      },
      {
        "command": "wildwood.source-control.main.commitAndCreatePr",
        "title": "Create PR (Main Compare)",
        "category": "Wildwood",
        "icon": "$(git-pull-request-create)"
      },
      {
        "command": "wildwood.source-control.main.commit",
        "title": "Commit (Main Compare)",
        "category": "Wildwood",
        "icon": "$(check)"
      },
      {
        "command": "wildwood.source-control.main.viewPr",
        "title": "View PR (Main Compare)",
        "category": "Wildwood",
        "icon": "$(link-external)"
      },
      {
        "command": "wildwood.source-control.main.pullFromRemote",
        "title": "Pull from remote",
        "category": "Wildwood",
        "icon": "$(git-pull)"
      },
      {
        "command": "wildwood.source-control.discard",
        "title": "Discard All Changes",
        "category": "Wildwood",
        "icon": "$(trash)"
      },
      {
        "command": "wildwood.source-control.refresh",
        "title": "Refresh",
        "category": "Wildwood",
        "icon": "$(refresh)"
      },
      {
        "command": "wildwood.source-control.skipCommitAndSync",
        "title": "Skip commit and sync",
        "category": "Wildwood"
      },
      {
        "command": "wildwood.source-control.syncToConfigRef",
        "title": "Sync to config ref (merge / create PR)",
        "category": "Wildwood"
      },
      {
        "command": "wildwood.openOnGitHub",
        "title": "Open on GitHub",
        "category": "Wildwood",
        "icon": "$(link-external)"
      },
      {
        "command": "wildwood.openPullRequests",
        "title": "Open Pull Requests",
        "category": "Wildwood",
        "icon": "$(git-pull-request)"
      },
      {
        "command": "wildwood.openIssues",
        "title": "Open Issues",
        "category": "Wildwood",
        "icon": "$(issues)"
      },
      {
        "command": "wildwood.openBranchOnGitHub",
        "title": "Open branch on GitHub",
        "category": "Wildwood",
        "icon": "$(link-external)"
      },
      {
        "command": "wildwood.closeEmbeddedEditor",
        "title": "Close embedded editor",
        "category": "Wildwood",
        "icon": "$(close)"
      }
    ],
    "customEditors": [
      {
        "viewType": "wildwood.imagePreview",
        "displayName": "Wildwood Image Preview",
        "selector": [
          {
            "filenamePattern": "*.png"
          },
          {
            "filenamePattern": "*.jpg"
          },
          {
            "filenamePattern": "*.jpeg"
          },
          {
            "filenamePattern": "*.gif"
          },
          {
            "filenamePattern": "*.webp"
          },
          {
            "filenamePattern": "*.svg"
          },
          {
            "filenamePattern": "*.bmp"
          },
          {
            "filenamePattern": "*.ico"
          }
        ],
        "priority": "default"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "wildwood.closeEmbeddedEditor",
          "group": "navigation@100",
          "when": "activeEditor && resourceScheme == wildwood-vfs"
        }
      ],
      "scm/title": [
        {
          "command": "wildwood.source-control.discard",
          "group": "navigation@1",
          "when": "scmProvider == wildwood-scm"
        },
        {
          "command": "wildwood.source-control.refresh",
          "group": "navigation@2",
          "when": "scmProvider == wildwood-scm"
        },
        {
          "command": "wildwood.openOnGitHub",
          "group": "navigation@3",
          "when": "scmProvider == wildwood-scm"
        },
        {
          "command": "wildwood.openPullRequests",
          "group": "navigation@4",
          "when": "scmProvider == wildwood-scm"
        },
        {
          "command": "wildwood.openIssues",
          "group": "navigation@5",
          "when": "scmProvider == wildwood-scm"
        }
      ],
      "scm/resourceGroup/context": [
        {
          "command": "wildwood.source-control.discard",
          "group": "inline@1",
          "when": "scmProvider == wildwood-scm && scmResourceGroup == changes"
        }
      ]
    }
  },
  "activationEvents": [
    "*",
    "onFileSystem:wildwood-vfs"
  ],
  "dependencies": {
    "tsdown": "catalog:",
    "wildwood-shared": "workspace:*",
    "wildwood-store": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/vscode": "1.109.0",
    "typescript": "catalog:"
  },
  "extensionKind": [
    "web"
  ],
  "engines": {
    "vscode": "^1.72.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "capabilities": {
    "virtualWorkspaces": true,
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "enabledApiProposals": [
    "scmActionButton"
  ]
}
