{
  "name": "wildwood-shared",
  "version": "0.1.0",
  "description": "Shared constants and utilities for Wildwood",
  "author": "Jeff See <jeff@wildwood.dev>",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lib:dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "format": "oxfmt ."
  },
  "devDependencies": {
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
