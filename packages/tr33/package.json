{
  "name": "tr33",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./nextjs": "./dist/nextjs/index.mjs",
    "./react": "./dist/react/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lib:dev": "tsdown --watch",
    "watch:deps": "tsdown --watch",
    "export": "npx drizzle-kit export --config drizzle.sqlite.ts | node scripts/sql-to-json.mjs",
    "playground": "pnpm srvx ./playground.ts --import=tsx",
    "studio": "npx drizzle-kit studio --config drizzle.sqlite.ts",
    "studio:app": "npx drizzle-kit studio --config drizzle.app.ts --port 3001",
    "studio:play": "npx drizzle-kit studio --config drizzle.play.ts --port 3002",
    "restart": "rm -rf tr33.db && pnpm run export && pnpm run studio",
    "restart:app": "rm -f ../../apps/shad-docs/tr33.db && pnpm run export && pnpm run studio:app",
    "restart:play": "rm -f ../../apps/play/tr33.db && pnpm run studio:play",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@turbo/gen": "^1.12.4",
