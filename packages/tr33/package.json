    "@types/shasum": "^1.0.2",
    "@types/unist": "^3.0.3",
    "dotenv": "^16.4.7",
    "fs-extra": "^11.3.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "srvx": "0.11.8",
    "tsdown": "0.18.2",
    "tsx": "4.21.0",
    "typescript": "5.5.4",
    "vite": "beta",
    "vitest": "4.0.18"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.2.13",
