{
  "name": "wildwood",
  "version": "0.1.0",
  "description": "Git-native content layer — Markdown and JSON in content/, typed Zod schemas, Git as CMS",
  "license": "MIT",
  "author": "Jeff See <jeff@wildwood.dev>",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./nextjs": "./dist/nextjs/index.mjs",
    "./nextjs/auth": "./dist/nextjs/auth.mjs",
    "./nextjs/branch": "./dist/nextjs/branch.mjs",
    "./nextjs/draft": "./dist/nextjs/draft.mjs",
    "./nextjs/handler": "./dist/nextjs/handler.mjs",
    "./nextjs/kit": "./dist/nextjs/kit.mjs",
    "./nextjs/resolve-active-ref": "./dist/nextjs/resolve-active-ref.mjs",
    "./nextjs/route": "./dist/nextjs/route.mjs",
    "./react": "./dist/react/index.mjs",
    "./react/markdown": "./dist/react/markdown.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "bundled-extension"
  ],
  "scripts": {
    "build": "pnpm --filter wildwood-shared run build 2>/dev/null || true && pnpm --filter wildwood-store run build && tsdown && node scripts/copy-bundled-extension.mjs",
    "build:deps": "pnpm --filter wildwood-store run build",
    "dev": "tsdown --watch",
    "lib:dev": "tsdown --watch",
    "watch:deps": "tsdown --watch",
    "export": "npx drizzle-kit export --config drizzle.sqlite.ts | node scripts/sql-to-json.mjs",
    "playground": "pnpm srvx ./playground.ts --import=tsx",
    "studio": "npx drizzle-kit studio --config drizzle.sqlite.ts",
    "studio:app": "npx drizzle-kit studio --config drizzle.app.ts --port 3001",
    "studio:play": "npx drizzle-kit studio --config drizzle.play.ts --port 3002",
    "restart": "rm -rf wildwood.db && pnpm run export && pnpm run studio",
    "restart:app": "rm -f ../../apps/shad-docs/wildwood.db && pnpm run export && pnpm run studio:app",
    "restart:play": "rm -f ../../apps/play/wildwood.db && pnpm run studio:play",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "next": "^16.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@turbo/gen": "^1.12.4",
    "@types/better-sqlite3": "^7.6.11",
    "@types/fs-extra": "^11.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/mdast": "^4.0.4",
    "@types/node": "^20.11.24",
    "@types/react": "18.3.0",
    "@types/react-dom": "18.3.1",
    "@types/shasum": "^1.0.2",
    "@types/unist": "^3.0.3",
    "dotenv": "^16.4.7",
    "fs-extra": "^11.3.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "srvx": "0.11.8",
    "tsdown": "0.18.2",
    "tsx": "4.21.0",
    "typescript": "5.5.4",
    "vite": "beta",
    "vitest": "4.0.18"
  },
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "@libsql/kysely-libsql": "^0.4.1",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/graphql": "^9.0.3",
    "@octokit/rest": "21.0.2",
    "@uiw/react-json-view": "^2.0.0-alpha.34",
    "wildwood-kit": "workspace:*",
    "wildwood-shared": "workspace:*",
    "@types/diff3": "^0.0.2",
    "buffer": "6.0.3",
    "diff3": "^0.0.4",
    "drizzle-kit": "catalog:",
    "drizzle-orm": "catalog:",
    "h3": "2.0.0-beta.5",
    "js-yaml": "^4.1.0",
    "kysely": "^0.28.17",
    "mdast-util-compact": "^5.0.0",
    "mdast-util-directive": "^3.1.0",
    "mdast-util-from-markdown": "^2.0.2",
    "mdast-util-frontmatter": "^2.0.1",
    "mdast-util-gfm": "^3.0.0",
    "mdast-util-to-markdown": "^2.1.2",
    "micromark-extension-directive": "^3.0.2",
    "micromark-extension-frontmatter": "^2.0.0",
    "micromark-extension-gfm": "^3.0.0",
    "minimatch": "^10.0.1",
    "neverthrow": "catalog:",
    "node-diff3": "^3.2.0",
    "shasum": "^1.0.2",
    "wildwood-store": "workspace:*",
    "unist-util-visit": "^5.0.0",
    "zod": "4.1.1"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.10.0"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts"
}
