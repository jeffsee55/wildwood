{
  "name": "wildwood-store",
  "version": "0.1.0",
  "description": "Git object store and merge primitives for Wildwood",
  "author": "Jeff See <jeff@wildwood.dev>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lib:dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "format": "oxfmt ."
  },
  "dependencies": {
    "node-diff3": "^3.2.0"
  },
  "devDependencies": {
    "@types/diff3": "^0.0.2",
    "tsdown": "0.18.2",
    "typescript": "5.5.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
