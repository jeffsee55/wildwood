{
  "name": "wildwood-kit",
  "version": "0.1.0",
  "description": "Client UI kit for Wildwood (React, shadcn/ui, Tailwind v4)",
  "author": "Jeff See <jeff@wildwood.dev>",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsdown",
    "lib:dev": "tsdown --watch",
    "watch:deps": "tsdown --watch",
    "lint": "oxlint .",
    "format": "oxfmt .",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@tailwindcss/vite": "catalog:",
    "@tsdown/css": "catalog:",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "0.544.0",
    "next-themes": "^0.4.6",
    "react": "catalog:",
    "react-dom": "catalog:",
    "shadcn": "^4.1.1",
    "sonner": "^2.0.5",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "catalog:",
    "tsdown": "catalog:",
    "tw-animate-css": "^1.3.4",
    "wildwood-shared": "workspace:*"
  },
  "devDependencies": {
    "@tailwindcss/cli": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "next": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  },
  "peerDependencies": {
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "inlinedDependencies": {
    "sonner": "2.0.5"
  }
}
