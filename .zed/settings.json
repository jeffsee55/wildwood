{
  // oxfmt is the single source of truth for formatting.
  // Uses --stdin-filepath so oxfmt resolves .oxfmtrc.json via directory walk.
  "format_on_save": "on",
  "formatter": {
    "external": {
      "command": "pnpm",
      "arguments": ["exec", "oxfmt", "--stdin-filepath", "{buffer_path}"]
    }
  },
  "remove_trailing_whitespace_on_save": false,
  "ensure_final_newline_on_save": false,

  // Tailwind CSS language server settings.
  // `suggestCanonicalClasses` is a noisy Tailwind v4 lint (default: warning) that flags
  // non-canonical forms like `!border-0` → `border-0!` or `[&_.foo]:bar` rewrites.
  // Disable it everywhere — we format with oxfmt, not Tailwind's canonical rewrite.
  // Zed runs two different Tailwind servers depending on filetype / version, so cover all ids.
  "lsp": {
    "tailwindcss-language-server": {
      "settings": {
        "tailwindCSS": {
          "lint": {
            "suggestCanonicalClasses": "ignore"
          }
        }
      }
    },
    "tailwindcss-intellisense": {
      "settings": {
        "tailwindCSS": {
          "lint": {
            "suggestCanonicalClasses": "ignore"
          }
        }
      }
    },
    "tailwindcss-intellisense-css": {
      "settings": {
        "tailwindCSS": {
          "lint": {
            "suggestCanonicalClasses": "ignore"
          }
        }
      }
    }
  },

  "languages": {
    "TypeScript": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "pnpm",
          "arguments": ["exec", "oxfmt", "--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "TSX": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "pnpm",
          "arguments": ["exec", "oxfmt", "--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "JavaScript": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "pnpm",
          "arguments": ["exec", "oxfmt", "--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "JSON": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "pnpm",
          "arguments": ["exec", "oxfmt", "--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "JSONC": {
      "format_on_save": "on",
      "formatter": {
