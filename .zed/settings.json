{
  // oxfmt is the single source of truth for formatting.
  // Uses --stdin-filepath so oxfmt resolves .oxfmtrc.json via directory walk.
  "format_on_save": "on",
  "formatter": {
    "external": {
      "command": "pnpm",
      "arguments": ["exec", "oxfmt", "--stdin-filepath", "{buffer_path}"]
    }
  },
  "remove_trailing_whitespace_on_save": false,
  "ensure_final_newline_on_save": false,

  // Tailwind CSS language server settings.
  // `suggestCanonicalClasses` (Tailwind v4, default: warning) flags non-canonical
  // forms, e.g. `!border-0` → `border-0!`, `w-[5.5rem]` → `w-22`. Some are worth
  // fixing (5.5rem == spacing 22, `!` suffix is the new v4 canonical), others are
  // noisy (internal `[&_.foo]:bar` shadcn rewrites). Keep as warning so the useful
  // ones surface; address them intentionally rather than silencing the whole rule.
  // Zed runs multiple Tailwind servers depending on version/filetype — cover all ids.
  "lsp": {
    "tailwindcss-language-server": {
      "settings": {
        "tailwindCSS": {
          "lint": {
            "suggestCanonicalClasses": "warning"
          }
        }
      }
    },
    "tailwindcss-intellisense": {
      "settings": {
        "tailwindCSS": {
          "lint": {
            "suggestCanonicalClasses": "warning"
          }
        }
      }
    },
    "tailwindcss-intellisense-css": {
      "settings": {
        "tailwindCSS": {
          "lint": {
            "suggestCanonicalClasses": "warning"
          }
        }
      }
    }
  },

  "languages": {
    "TypeScript": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "pnpm",
          "arguments": ["exec", "oxfmt", "--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "TSX": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "pnpm",
          "arguments": ["exec", "oxfmt", "--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "JavaScript": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "pnpm",
          "arguments": ["exec", "oxfmt", "--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "JSON": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "pnpm",
          "arguments": ["exec", "oxfmt", "--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "JSONC": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "pnpm",
          "arguments": ["exec", "oxfmt", "--stdin-filepath", "{buffer_path}"]
