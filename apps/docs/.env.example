# ── Canonical env — only these should exist in Vercel ───────────────────────
# Turso (from Vercel marketplace integration)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# GitHub App — from `wildwood` manifest conversion (single App gives both git + OAuth)
# Same App provides both:
# - git writes via GITHUB_APP_ID + GITHUB_PRIVATE_KEY (+ optional INSTALLATION_ID)
# - OAuth sign-in via GITHUB_CLIENT_ID + GITHUB_CLIENT_SECRET (App's OAuth pair)
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_SLUG=
GITHUB_APP_INSTALLATION_ID=  # optional optimization

# Auth cookie signing — generate: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Who may sign in — parsed in YOUR `authenticate` callback, not inside wildwood
# Example in route.ts:
#   authenticate: async ({ user }) => allowList.has(user.email?.toLowerCase() ?? "")
ALLOWED_EMAILS=you@example.com

# ── Optional / dev only ──────────────────────────────────────────────────────
# Base origin — optional, autodetected from Request (x-forwarded-host/proto).
# Only set if you need fixed canonical origin:
# BETTER_AUTH_URL=https://myapp.com
# Trusted origins — optional, autodetected too. Map in userland if needed:
#   trustedOrigins: (req) => [new URL(req!.url).origin, "https://studio.myapp.com"]

WILDWOOD_LOCAL_PATH=         # monorepo / CI local git root override
WILDWOOD_SOURCE=github|local # force GitHub remote in dev (default: local)
