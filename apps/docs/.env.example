# Repo identity (namespace in the index DB)
TR33_GITHUB_ORG=jeffsee55
TR33_GITHUB_REPO=tr33
# Ref key in `_refs` (default on Vercel: deployment commit SHA; else `main`)
TR33_DOCS_REF=main

# LibSQL / Turso — required on Vercel build + production so prefetch persists
TR33_DOCS_DATABASE_URL=
TR33_DOCS_DATABASE_AUTH_TOKEN=

# GitHub App — optional; only for /api toolbar edits (not for reading docs)
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_SLUG=

# local = dev/build use repo content/ | github = force GitHub remote
# TR33_DOCS_SOURCE=local
