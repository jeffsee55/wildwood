# Repo identity (local + GitHub remote)
TR33_GITHUB_ORG=jeffsee55
TR33_GITHUB_REPO=tr33
TR33_DOCS_REF=main
# Local indexing ref when `content/` is on disk (default: VERCEL_GIT_COMMIT_SHA or HEAD)
# TR33_DOCS_LOCAL_REF=HEAD

# GitHub App — production runtime /api only (`next build` uses local `content/`)
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_SLUG=

# LibSQL / Turso — optional locally; use on Vercel so build-time indexing persists
TR33_DOCS_DATABASE_URL=
TR33_DOCS_DATABASE_AUTH_TOKEN=

# Force source: local | github (default: local for dev + next build, github for prod runtime)
# TR33_DOCS_SOURCE=local
