# Repo identity (namespace in the index DB)
TR33_GITHUB_ORG=jeffsee55
TR33_GITHUB_REPO=tr33
# Ref key in `_refs` (default on Vercel: deployment commit SHA; else `main`)
TR33_DOCS_REF=main

# LibSQL / Turso — required on Vercel build + production so prefetch persists
TR33_DOCS_DATABASE_URL=
TR33_DOCS_DATABASE_AUTH_TOKEN=

# GitHub App — required on Vercel for the embedded editor (/api/git, worktrees)
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
# Optional: skips lookup via GET /repos/{owner}/{repo}/installation
GITHUB_APP_INSTALLATION_ID=
# Required for the install prompt URL (https://github.com/apps/{slug}/installations/new)
GITHUB_APP_SLUG=

# local = dev/build use repo content/ | github = force GitHub remote
# TR33_DOCS_SOURCE=local

# Optional: pin VS Code web (defaults to latest stable commit on main.vscode-cdn.net)
# TR33_VSCODE_WEB_COMMIT=
# TR33_VSCODE_WEB_VERSION=

