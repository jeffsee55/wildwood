# Repo identity (local + GitHub remote)
TR33_GITHUB_ORG=jeffsee55
TR33_GITHUB_REPO=tr33
TR33_DOCS_REF=main
# Local indexing ref when `content/` is on disk (default: VERCEL_GIT_COMMIT_SHA or HEAD)
# TR33_DOCS_LOCAL_REF=HEAD

# GitHub App — toolbar + /api edits (optional for read-only docs)
# Requires the app installed on TR33_GITHUB_ORG/TR33_GITHUB_REPO, or set:
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_SLUG=

# LibSQL / Turso — use on Vercel so build-time indexing persists for SSR
TR33_DOCS_DATABASE_URL=
TR33_DOCS_DATABASE_AUTH_TOKEN=

# local = always use repo content/ | github = always use GitHub App remote
# Default: local for build; GitHub only when GITHUB_APP_INSTALLATION_ID is set
# TR33_DOCS_SOURCE=local
