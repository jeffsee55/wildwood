{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "GITHUB_APP_ID",
    "GITHUB_PRIVATE_KEY",
    "GITHUB_APP_INSTALLATION_ID",
    "GITHUB_APP_SLUG",
    "GITHUB_APP_NAME",
    "GITHUB_TOKEN",
    "WILDWOOD_*",
    "NEXT_PUBLIC_ORIGIN",
    "NEXT_PUBLIC_SITE_URL",
    "ORIGIN",
    "SITE_URL",
    "VERCEL",
    "VERCEL_ENV",
    "VERCEL_TARGET_ENV",
    "VERCEL_DEPLOYMENT_ID",
    "VERCEL_PROJECT_ID",
    "VERCEL_REGION",
    "VERCEL_URL",
    "VERCEL_BRANCH_URL",
    "VERCEL_PROJECT_PRODUCTION_URL",
    "VERCEL_GIT_PROVIDER",
    "VERCEL_GIT_REPO_OWNER",
    "VERCEL_GIT_REPO_SLUG",
    "VERCEL_GIT_REPO_ID",
    "VERCEL_GIT_COMMIT_REF",
    "VERCEL_GIT_COMMIT_SHA",
    "VERCEL_GIT_COMMIT_MESSAGE",
    "VERCEL_GIT_COMMIT_AUTHOR_LOGIN",
    "VERCEL_GIT_COMMIT_AUTHOR_NAME",
    "VERCEL_GIT_PULL_REQUEST_ID",
    "VERCEL_GIT_PREVIOUS_SHA",
    "VERCEL_SKEW_PROTECTION_ENABLED",
    "VERCEL_AUTOMATION_BYPASS_SECRET",
    "TURSO_DATABASE_URL",
    "TURSO_AUTH_TOKEN",
    "LIBSQL_URL",
    "LIBSQL_AUTH_TOKEN",
    "NEXT_PHASE"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "GITHUB_APP_ID",
        "GITHUB_PRIVATE_KEY",
        "GITHUB_APP_INSTALLATION_ID",
        "GITHUB_APP_SLUG",
        "GITHUB_APP_NAME",
        "GITHUB_TOKEN",
        "WILDWOOD_*",
        "NEXT_PUBLIC_ORIGIN",
        "NEXT_PUBLIC_SITE_URL",
        "ORIGIN",
        "SITE_URL",
        "VERCEL",
        "VERCEL_ENV",
        "VERCEL_TARGET_ENV",
        "VERCEL_DEPLOYMENT_ID",
        "VERCEL_PROJECT_ID",
        "VERCEL_REGION",
        "VERCEL_URL",
        "VERCEL_BRANCH_URL",
        "VERCEL_PROJECT_PRODUCTION_URL",
        "VERCEL_GIT_PROVIDER",
        "VERCEL_GIT_REPO_OWNER",
        "VERCEL_GIT_REPO_SLUG",
        "VERCEL_GIT_REPO_ID",
        "VERCEL_GIT_COMMIT_REF",
        "VERCEL_GIT_COMMIT_SHA",
        "VERCEL_GIT_COMMIT_MESSAGE",
        "VERCEL_GIT_COMMIT_AUTHOR_LOGIN",
        "VERCEL_GIT_COMMIT_AUTHOR_NAME",
        "VERCEL_GIT_PULL_REQUEST_ID",
        "VERCEL_GIT_PREVIOUS_SHA",
        "TURSO_DATABASE_URL",
        "TURSO_AUTH_TOKEN",
        "LIBSQL_URL",
        "LIBSQL_AUTH_TOKEN",
        "NEXT_PHASE"
      ]
    },
    "wildwood#build": {
      "dependsOn": [
        "wildwood-store#build",
        "wildwood-kit#build",
        "wildwood-ui#build",
        "wildwood-vscode#build"
      ],
      "outputs": ["dist/**", "bundled-extension/**"]
    },
    "next:dev": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "dependsOn": ["^build"]
    },
    "studio:play": {
      "dependsOn": ["^build"]
    }
  }
}
